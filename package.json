{
  "name": "forgify",
  "version": "0.1.0",
  "private": true,
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -n fe,el --kill-others-on-fail \"npm run dev:fe\" \"npm run dev:el\"",
    "dev:fe": "npm --prefix frontend run dev",
    "dev:el": "wait-on http://localhost:5173 && tsc -p electron/tsconfig.json && electron . --dev",
    "build:go": "cd backend && go build -o ../dist-electron/forgify-backend .",
    "build:fe": "npm --prefix frontend run build",
    "build:el": "tsc -p electron/tsconfig.json",
    "build": "npm run build:go && npm run build:fe && npm run build:el"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "concurrently": "^9.0.0",
    "electron": "^35.0.0",
    "typescript": "^5.4.0",
    "wait-on": "^8.0.0"
  }
}
